from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from typing import List
import numpy as np

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Laptop Data
LAPTOPS = [
    "Acer Nitro 5 AN515-57-505V",
    "Lenovo ThinkPad L13 Gen 2",
    "Dell Latitude 7530",
    "MSI Bravo 15 B5DD-007XES",
    "Asus ROG Zephyrus G14 GA401II-HE004T",
    "HP 17-CN0018NS",
    "Apple Macbook Air Apple M2",
    "Gigabyte AERO 15 OLED KC-8ES5130VP",
    "Laptop MSI Modern 14 F13MG 466VN",
    "Laptop gaming Acer Predator Helios 18 PH18 73 98AQ"
]

# Criteria: [Performance, Resolution, Capacity, Portability, Battery, Price]
CRITERIA = ["Performance", "Resolution", "Capacity", "Portability", "Battery", "Price"]
CRITERIA_TYPES = np.array([1, 1, 1, 1, 1, 0]) # 1: benefit, 0: cost

# Decision Matrix from main.py (Saaty 1-9 scale representation of laptop specs)
X = np.array([
    [7,5,6,3,4,7], # Acer Nitro
    [5,5,5,7,7,5], # Lenovo
    [6,5,6,6,7,4], # Dell
    [7,5,6,3,4,7], # MSI Bravo
    [9,7,7,7,6,3], # Asus ROG
    [3,5,4,2,5,8], # HP
    [8,7,6,9,9,4], # Apple
    [8,9,8,4,5,2], # Gigabyte
    [5,5,5,8,7,6], # MSI Modern
    [9,7,9,1,3,1]  # Acer Predator
], dtype=float)

class ComparisonRequest(BaseModel):
    # Flattened upper triangle of the pairwise matrix (15 values for 6 criteria)
    # comparisons: [c01, c02, c03, c04, c05, c12, c13, c14, c15, c23, c24, c25, c34, c35, c45]
    comparisons: List[float]

def calculate_ahp(comparisons: List[float]):
    n = len(CRITERIA)
    A = np.eye(n)
    
    idx = 0
    for i in range(n):
        for j in range(i + 1, n):
            val = comparisons[idx]
            A[i, j] = val
            A[j, i] = 1.0 / val
            idx += 1
            
    # Calculate weights using Eigenvector method
    eigvals, eigvecs = np.linalg.eig(A)
    max_idx = np.argmax(eigvals.real)
    max_eigval = eigvals[max_idx].real
    weights = eigvecs[:, max_idx].real
    weights = weights / np.sum(weights)
    
    # Consistency Ratio
    RI = [0, 0, 0.58, 0.9, 1.12, 1.24, 1.32, 1.41, 1.45, 1.49]
    CI = (max_eigval - n) / (n - 1) if n > 1 else 0
    CR = CI / RI[n-1] if n > 1 else 0
    
    return weights.tolist(), CR

def calculate_topsis(weights: List[float]):
    W = np.array(weights)
    
    # Step 1: Normalize
    norm = np.sqrt((X**2).sum(axis=0))
    R = X / norm
    
    # Step 2: Weighted Normalize
    V = R * W
    
    # Step 3: Ideal best & worst
    ideal_best = np.zeros(V.shape[1])
    ideal_worst = np.zeros(V.shape[1])
    
    for j in range(V.shape[1]):
        if CRITERIA_TYPES[j] == 1:
            ideal_best[j] = np.max(V[:, j])
            ideal_worst[j] = np.min(V[:, j])
        else:
            ideal_best[j] = np.min(V[:, j])
            ideal_worst[j] = np.max(V[:, j])
            
    # Step 4: Distance
    dist_best = np.sqrt(((V - ideal_best)**2).sum(axis=1))
    dist_worst = np.sqrt(((V - ideal_worst)**2).sum(axis=1))
    
    # Step 5: Score
    scores = dist_worst / (dist_best + dist_worst)
    return scores.tolist()

@app.post("/calculate")
async def calculate(request: ComparisonRequest):
    try:
        weights, cr = calculate_ahp(request.comparisons)
        scores = calculate_topsis(weights)
        
        results = []
        for i in range(len(LAPTOPS)):
            results.append({
                "name": LAPTOPS[i],
                "score": float(scores[i])
            })
            
        # Sort by score descending
        results.sort(key=lambda x: x["score"], reverse=True)
        
        return {
            "weights": {CRITERIA[i]: float(weights[i]) for i in range(len(CRITERIA))},
            "cr": float(cr),
            "ranking": results
        }
    except Exception as e:
        import traceback
        print(traceback.format_exc())
        raise HTTPException(status_code=400, detail=str(e))

@app.get("/laptops")
async def get_laptops():
    return LAPTOPS

@app.get("/criteria")
async def get_criteria():
    return CRITERIA

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
